rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // --- BASIC HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getRoleData(roleId) {
      return get(/databases/$(database)/documents/roles/$(roleId)).data;
    }

    // --- ROLE CHECKS ---
    
    function isSuperAdmin() {
      // Priorité 1 : Email hardcodé (0 Doc Read)
      // Priorité 2 : Role ID direct
      return isSignedIn() && (
        request.auth.token.email == 'magloire078@gmail.com' ||
        getUserData().roleId in ['super-admin', 'LHcHyfBzile3r0vyFOFb']
      );
    }
    
    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn() && (
          getUserData().roleId == 'administrateur' || 
          hasResourcePermission('admin', 'read')
        )
      );
    }

    // --- PERMISSION MATRIX HELPER (Optimized) ---
    
    function hasResourcePermission(resource, action) {
      if (!isSignedIn()) { return false; }
      
      let user = getUserData();
      let userExplicit = user.get(['resourcePermissions', resource, action], null);
      
      // 1. Surcharge Utilisateur (Si définie, elle gagne)
      if (userExplicit != null) {
        return userExplicit == true;
      }
      
      // 2. Permission par défaut du Rôle
      return user.roleId != null && 
             getRoleData(user.roleId).resourcePermissions[resource][action] == true;
    }

    // --- DEFAULT DENY ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- SYSTEM COLLECTIONS ---
    
    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin() || (
        request.auth.uid == userId && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roleId', 'resourcePermissions'])
      );
      allow delete: if isAdmin();
    }

    // --- EMPLOYEES & HR ---
    
    match /employees/{employeeId} {
      allow read: if hasResourcePermission('employees', 'read') || 
                   (resource.data.status == 'Actif' && (
                     resource.data.departmentId == '9ywKFDgVMS86rZLPYhpm' || 
                     resource.data.matricule.upper().startsWith('DIR') ||
                     resource.data.matricule.upper().startsWith('PRE') ||
                     resource.data.poste in ['Président', 'Secrétaire Général', 'Membre du Directoire']
                   ));
      allow create: if hasResourcePermission('employees', 'create');
      allow update: if hasResourcePermission('employees', 'update');
      allow delete: if hasResourcePermission('employees', 'delete');
      
      match /history/{eventId} {
        allow read: if hasResourcePermission('employees', 'read');
        allow create, update: if hasResourcePermission('employees', 'update');
        allow delete: if isAdmin();
      }
    }

    // --- TERRITORIAL OBSERVATORY ---
    
    match /villages/{villageId} {
      allow read: if hasResourcePermission('villages', 'read');
      allow create: if hasResourcePermission('villages', 'create');
      allow update: if hasResourcePermission('villages', 'update');
      allow delete: if hasResourcePermission('villages', 'delete');
    }

    match /chiefs/{chiefId} {
      allow read: if hasResourcePermission('chiefs', 'read');
      allow create: if hasResourcePermission('chiefs', 'create');
      allow update: if hasResourcePermission('chiefs', 'update');
      allow delete: if hasResourcePermission('chiefs', 'delete');
    }

    match /conflicts/{conflictId} {
      allow read: if hasResourcePermission('conflicts', 'read');
      allow create: if hasResourcePermission('conflicts', 'create');
      allow update: if hasResourcePermission('conflicts', 'update');
      allow delete: if hasResourcePermission('conflicts', 'delete');
    }

    match /regencies/{id} {
      allow read: if isSignedIn();
      allow create, update: if hasResourcePermission('chiefs', 'update') || isAdmin();
      allow delete: if isAdmin();
    }

    // --- BUDGET & FINANCE ---
    
    match /budgetLines/{lineId} {
      allow read: if hasResourcePermission('budget', 'read');
      allow create: if hasResourcePermission('budget', 'create');
      allow update: if hasResourcePermission('budget', 'update');
      allow delete: if hasResourcePermission('budget', 'delete');
    }

    match /payroll/{payrollId} {
      allow read: if hasResourcePermission('payroll', 'read') || (isSignedIn() && resource.data.employeeId == getUserData().employeeId);
      allow create, update: if hasResourcePermission('payroll', 'update');
      allow delete: if hasResourcePermission('payroll', 'delete');
    }

    // --- LOGISTICS & ASSETS ---
    
    match /heritage/{assetId} {
      allow read: if hasResourcePermission('heritage', 'read');
      allow create: if hasResourcePermission('heritage', 'create');
      allow update: if hasResourcePermission('heritage', 'update');
      allow delete: if hasResourcePermission('heritage', 'delete');
    }

    match /fleet/{vehicleId} {
      allow read: if hasResourcePermission('fleet', 'read');
      allow create, update, delete: if hasResourcePermission('fleet', 'update');
    }

    match /supplies/{supplyId} {
      allow read: if hasResourcePermission('supplies', 'read');
      allow create, update, delete: if hasResourcePermission('supplies', 'update');
    }

    match /supply_transactions/{id} {
      allow read: if hasResourcePermission('supplies', 'read');
      allow create: if hasResourcePermission('supplies', 'update');
      allow update, delete: if isAdmin();
    }

    match /fuel_transactions/{id} {
      allow read: if hasResourcePermission('fuel', 'read');
      allow create, update, delete: if hasResourcePermission('fuel', 'update');
    }

    // --- MISSIONS & LEAVES ---
    
    match /missions/{missionId} {
      allow read: if hasResourcePermission('missions', 'read') || 
                   (isSignedIn() && getUserData().get('employeeId', '') in resource.data.get('participantIds', []));
      allow create: if hasResourcePermission('missions', 'create');
      allow update: if hasResourcePermission('missions', 'update');
      allow delete: if hasResourcePermission('missions', 'delete');
    }
    
    match /leaves/{leaveId} {
      allow read: if hasResourcePermission('leaves', 'read') || (isSignedIn() && resource.data.employeeId == getUserData().employeeId);
      allow create: if hasResourcePermission('leaves', 'create') || (isSignedIn() && request.resource.data.employeeId == getUserData().employeeId);
      allow update: if hasResourcePermission('leaves', 'update');
      allow delete: if hasResourcePermission('leaves', 'delete');
    }

    // --- ADMINISTRATION & SETTINGS ---
    
    match /departments/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /directions/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /services/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /audit_log/{id} {
      allow read: if hasResourcePermission('audit-log', 'read');
      allow create: if isSignedIn();
    }

    match /notifications/{id} { 
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == 'all');
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // --- TICKETS & SUPPORT ---
    
    match /tickets/{id} { 
      allow read: if isSignedIn() && (resource.data.createdBy == request.auth.uid || hasResourcePermission('tickets', 'read'));
      allow create: if isSignedIn();
      allow update: if resource.data.createdBy == request.auth.uid || hasResourcePermission('tickets', 'update');
      allow delete: if isAdmin();
    }

    // --- NEWS & REPOSITORY ---
    
    match /news/{newsId} {
      allow read: if isSignedIn(); 
      allow write: if hasResourcePermission('news', 'update');
    }

    match /repository/{id} { 
      allow read: if hasResourcePermission('repository', 'read'); 
      allow write: if hasResourcePermission('repository', 'update'); 
    }
  }
}
