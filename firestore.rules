rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check context
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasPermission(permission) {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().permissions != null && permission in getUserData().permissions) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().roleId != null && exists(/databases/$(database)/documents/roles/$(getUserData().roleId)) && permission in get(/databases/$(database)/documents/roles/$(getUserData().roleId)).data.permissions)
      );
    }

    // Role checks based on roleId
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'magloire078@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().roleId in ['dirigeant-president', 'super-admin'])
      );
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'magloire078@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().roleId in [
           'dirigeant-president', 
           'cadre-superieur-directeur', 
           'administrateur', 
           'administrateurs', 
           'comptable', 
           'comptables',
           'super-admin'
         ]) || 
        hasPermission('page:admin:view')
      );
    }

    function isComptable() {
      return isAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData().roleId in ['comptable', 'comptables']
      );
    }
    
    function isHR() {
      return isAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        (getUserData().roleId in ['manager-rh', 'rh', 'responsable-rh'] || hasPermission('group:personnel:view'))
      );
    }

    function isMediation() {
      return isAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        (getUserData().roleId in ['mediateur', 'mediateurs', 'mediation', 'mediations'] || 
         hasPermission('page:conflicts:view') || 
         hasResourcePermission('conflicts', 'read'))
      );
    }

    function hasResourcePermission(resource, action) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().roleId != null &&
             exists(/databases/$(database)/documents/roles/$(getUserData().roleId)) &&
             get(/databases/$(database)/documents/roles/$(getUserData().roleId)).data.resourcePermissions[resource][action] == true;
    }

    function isPatrimoine() {
      return isAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        (getUserData().roleId in [
          'manager-rh', 'responsable-it', 'it', 'gestionnaire-stock', 'patrimoine', 'patrimoines'
        ] ||
        hasPermission('page:fleet:view') || 
        hasPermission('page:supplies:view') ||
        hasResourcePermission('supplies', 'update') ||
        hasResourcePermission('fleet', 'update') ||
        hasResourcePermission('fuel', 'update'))
      );
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Roles: Only Super Admin can write, all registered can read
    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    
    // Users: Read own or admin, write own (limited) or admin
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roleId', 'permissions'])) || isAdmin();
      allow delete: if isAdmin();
    }

    // Employees: Allow public read of basic info for landing page, full access for HR
    match /employees/{employeeId} {
      allow read: if true; 
      allow write: if isHR();
      
      match /history/{eventId} {
        allow read: if isHR() || (isSignedIn() && getUserData().employeeId == employeeId);
        allow write: if isHR();
      }
    }

    // Conflicts & Mapping: Restrict to Mediation/Admins
    match /conflicts/{conflictId} {
      allow read: if isMediation();
      allow create: if isSignedIn();
      allow update, delete: if isMediation();
    }
    
    match /villages/{villageId} {
      allow read: if isSignedIn();
      allow write: if isMediation();
    }

    match /chiefs/{chiefId} {
      allow read: if true;
      allow write: if isMediation();
    }

    match /conflict-types/{id} {
      allow read: if isSignedIn();
      allow write: if isMediation();
    }

    // Missions, Leaves, Payroll: Owner or Admin
    match /missions/{missionId} {
      allow read: if true; // Public institutional missions
      allow write: if isAdmin() || isComptable() || (isSignedIn() && (request.resource.data.employeeId == getUserData().employeeId));
    }
    
    match /leaves/{leaveId} {
      allow read: if isHR() || (isSignedIn() && (resource == null || resource.data.employeeId == getUserData().employeeId));
      allow write: if isHR() || (isSignedIn() && (request.resource.data.employeeId == getUserData().employeeId));
    }

    match /evaluations/{evaluationId} {
      allow read: if isHR() || (isSignedIn() && (resource == null || resource.data.employeeId == getUserData().employeeId || resource.data.managerId == request.auth.uid));
      allow write: if isHR() || (isSignedIn() && (resource == null || resource.data.managerId == request.auth.uid));
    }
    
    match /payroll/{payrollId} {
      allow read: if isHR() || isComptable() || (isSignedIn() && resource.data.employeeId == getUserData().employeeId);
      allow write: if isHR() || isComptable();
    }

    match /budgetLines/{lineId} {
      allow read: if isSignedIn();
      allow write: if isComptable() || isAdmin();
    }

    // Infrastructure & Assets
    match /heritage/{assetId} {
      allow read: if isSignedIn();
      allow write: if isPatrimoine();
    }

    match /assets/{assetId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isPatrimoine() || isAdmin();
    }

    match /fleet/{vehicleId} {
      allow read: if isSignedIn();
      allow write: if isPatrimoine();
    }

    match /supplies/{supplyId} {
      allow read: if isSignedIn();
      allow write: if isPatrimoine();
    }

    match /supply_transactions/{id} {
      allow read: if isSignedIn();
      allow write: if isPatrimoine();
    }

    match /customs/{id} {
      allow read: if isSignedIn();
      allow write: if isMediation() || isAdmin();
    }

    // News: Public read, Admin write
    match /news/{newsId} {
      allow read: if true; // Public news
      allow write: if isAdmin();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']);
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Other collections
    match /departments/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /directions/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /services/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /repository/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /tickets/{id} { allow read, write: if isSignedIn(); }
    
    match /notifications/{id} { 
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == 'all');
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /print_logs/{id} {
      allow create: if isSignedIn();
      allow read: if isHR();
    }

    match /regency_history/{historyId} {
      allow read: if isSignedIn();
      allow write: if isMediation();
    }

    // Fuel Management
    match /fuel_providers/{id} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin() || isPatrimoine() || hasResourcePermission('fuel', 'create');
      allow update: if isSuperAdmin() || isPatrimoine() || hasResourcePermission('fuel', 'update');
      allow delete: if isSuperAdmin() || isPatrimoine() || hasResourcePermission('fuel', 'delete');
    }

    match /fuel_cards/{id} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin() || isPatrimoine() || hasResourcePermission('fuel', 'create');
      allow update: if isSuperAdmin() || isPatrimoine() || hasResourcePermission('fuel', 'update');
      allow delete: if isSuperAdmin() || isPatrimoine() || hasResourcePermission('fuel', 'delete');
    }

    match /fuel_transactions/{id} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin() || isPatrimoine() || hasResourcePermission('fuel', 'create');
      allow update: if isSuperAdmin() || isPatrimoine() || hasResourcePermission('fuel', 'update');
      allow delete: if isSuperAdmin() || isPatrimoine() || hasResourcePermission('fuel', 'delete');
    }
  }
}
